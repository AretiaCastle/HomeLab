# General 
PROJECT='project'
CRON_FILEPATHPATH='/etc/crontab'
DEPLOYMENTS_BASE_PATH="/home/$USER/devops/deployments"
DEPLOYMENTS_DOCKER_VOLUMES="$DEPLOYMENTS_BASE_PATH/volumes"
DEPLOYMENTS_BACKUPS_PATH="$DEPLOYMENTS_BASE_PATH/backups"

# DNS Service
## Pihole
PIHOLE_BACKUP_PATH="$DEPLOYMENTS_BACKUPS_PATH/pihole"
# DuckDNS Configuration
# Get your token from: https://www.duckdns.org/
duckdns_domain='your-domain'
duckdns_token='your-token'

# VPN 
## WGDashboard
WGDASHBOARD_BACKUP_PATH="$DEPLOYMENTS_BACKUPS_PATH/nginx"
WGDASHBOARD_WEB_INTERFACE_PORT=10086
WGDASHBOARD_VPN_PORT=51820
WGDASHBOARD_MAIN_VOLUME_PATH="$DEPLOYMENTS_DOCKER_VOLUMES/wgdashboard"
WGDASHBOARD_ACONF_VOLUME_PATH="$WGDASHBOARD_MAIN_VOLUME_PATH/aconf"
WGDASHBOARD_CONF_VOLUME_PATH="$WGDASHBOARD_MAIN_VOLUME_PATH/conf"
WGDASHBOARD_DATA_VOLUME_PATH="$WGDASHBOARD_MAIN_VOLUME_PATH/data"

# Ingress
## nginx-proxy-manager
NGINX_PROXY_BACKUP_PATH="$DEPLOYMENTS_BACKUPS_PATH/nginx"
NGINX_PROXY_WEB_INTERFACE_PORT=10081
NGINX_PROXY_MAIN_VOLUME_PATH="$DEPLOYMENTS_DOCKER_VOLUMES/nginx_proxy"
NGINX_PROXY_DATA_VOLUME_PATH="$NGINX_PROXY_MAIN_VOLUME_PATH/data"
NGINX_PROXY_LETSENCRYPT_VOLUME_PATH="$NGINX_PROXY_MAIN_VOLUME_PATH/letsencrypt"
